{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ]
    },
    "chrome-devtools": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "source ~/.nvm/nvm.sh >/dev/null 2>&1 || true; nvm use 24 >/dev/null 2>&1 || true; npx -y chrome-devtools-mcp@latest"
      ]
    },
    "mcp-obsidian": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "source ~/.nvm/nvm.sh >/dev/null 2>&1 || true; nvm use 24 >/dev/null 2>&1 || true; npx -y @mauricio.wolff/mcp-obsidian@latest \"/path/to/your/local/repo\""
      ]
    },
    "notebooklm-mcp": {
      "command": "/opt/homebrew/bin/uvx",
      "args": [
        "--python",
        ">=3.12",
        "--from",
        "notebooklm-mcp-cli",
        "--with",
        "fakeredis<2.35",
        "notebooklm-mcp"
      ]
    },
    "claude-code": {
      "command": "claude",
      "args": ["mcp", "serve"]
    },
    "gemini-cli": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "source ~/.nvm/nvm.sh >/dev/null 2>&1 || true; nvm use 24 >/dev/null 2>&1 || true; npx -y mcp-gemini-cli --allow-npx"
      ]
    },
    "codex-tool": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "source ~/.nvm/nvm.sh >/dev/null 2>&1 || true; nvm use 24 >/dev/null 2>&1 || true; codex mcp-server"
      ]
    },
    "rag-memory": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "source ~/.nvm/nvm.sh >/dev/null 2>&1 || true; nvm use 24 >/dev/null 2>&1 || true; npx -y rag-memory-epf-mcp@latest"
      ],
      "env": {
        "DB_FILE_PATH": "{{PROJECT_ROOT}}/.memory/rag-memory.db"
      },
      "alwaysAllow": [
        "createEntities",
        "createRelations",
        "addObservations",
        "deleteEntities",
        "deleteObservations",
        "deleteRelations",
        "updateRelations",
        "readGraph",
        "searchNodes",
        "openNodes",
        "getNeighbors",
        "getKnowledgeGraphStats",
        "exportGraph",
        "importGraph",
        "hybridSearch",
        "getDetailedContext",
        "embedAllEntities",
        "storeDocument",
        "chunkDocument",
        "embedChunks",
        "extractTerms",
        "deleteDocuments",
        "listDocuments",
        "linkEntitiesToDocument",
        "getGraphMetrics",
        "detectCommunities",
        "analyzeGraphStructure",
        "getMigrationStatus",
        "runMigrations",
        "rollbackMigration"
      ]
    }
  }
}