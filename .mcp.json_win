{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ]
    },
    "chrome-devtools": {
      "command": "C:\\Program Files\\nodejs\\npx.cmd",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "mcp-obsidian": {
      "command": "C:\\Program Files\\nodejs\\npx.cmd",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "G:\\My Drive\\PARADocumentSystem"
      ]
    },
    "gemini-cli": {
      "command": "C:\\Program Files\\nodejs\\npx.cmd",
      "args": [
        "-y",
        "mcp-gemini-cli",
        "--allow-npx"
      ]
    },
    "notebooklm-mcp": {
      "command": "C:\\Users\\heeso\\.local\\bin\\uvx.exe",
      "args": [
        "--from",
        "notebooklm-mcp-cli",
        "notebooklm-mcp"
      ]
    },
    "rag-memory": {
      "command": "C:\\Program Files\\nodejs\\npx.cmd",
      "args": [
        "-y",
        "rag-memory-epf-mcp@latest"
      ],
      "env": {
        "DB_FILE_PATH": "G:\\My Drive\\PARADocumentSystem\\--0-CollectLOG\\Ultimate_AI_Personal_Assistant\\.memory\\rag-memory.db"
      },
      "alwaysAllow": [
        "createEntities",
        "createRelations",
        "addObservations",
        "deleteEntities",
        "deleteObservations",
        "deleteRelations",
        "updateRelations",
        "readGraph",
        "searchNodes",
        "openNodes",
        "getNeighbors",
        "getKnowledgeGraphStats",
        "exportGraph",
        "importGraph",
        "hybridSearch",
        "getDetailedContext",
        "embedAllEntities",
        "storeDocument",
        "chunkDocument",
        "embedChunks",
        "extractTerms",
        "deleteDocuments",
        "listDocuments",
        "linkEntitiesToDocument",
        "getGraphMetrics",
        "detectCommunities",
        "analyzeGraphStructure",
        "getMigrationStatus",
        "runMigrations",
        "rollbackMigration"
      ]
    }
  }
}